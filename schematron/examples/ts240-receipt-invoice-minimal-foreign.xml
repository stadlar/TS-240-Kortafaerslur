<?xml version="1.0" encoding="UTF-8"?>
<!-- Minimal TS240 card-transaction receipt with a FOREIGN merchant.
     Seller legal id (BT-30) = "0" with NO schemeID (the spec allows a dummy/0 for
     non-Icelandic merchants; IS-R-002 only requires scheme 0196 for Icelandic sellers).
     Fintech sender (BT-34 EndpointID) = Fintech Solution (kennitala 9090909090, scheme 0196).
     VAT: a foreign merchant carrying no tax identifier cannot use category S/E/Z (EN 16931
     BR-S-02/BR-E-02/BR-Z-02 require a seller VAT or tax id). Category O (not subject to VAT,
     out of scope) is used with an exemption reason. NOTE: TS240 4.6 lists only S/AA/E/Z, not
     O - see docs/ts240-spec-issues.md. -->
